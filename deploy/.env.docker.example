# ═══════════════════════════════════════════════════════════════
# Vexira Host — Docker production env
# Copy → deploy/.env.docker  (DO NOT commit real secrets)
# docker compose -f docker/docker-compose.yml --env-file deploy/.env.docker up -d --build
# ═══════════════════════════════════════════════════════════════

# Host ports (Plesk reverse proxy → these)
FRONTEND_HOST_PORT=3000
BACKEND_HOST_PORT=4000

# Public URLs (baked into frontend at build time)
NEXT_PUBLIC_APP_URL=https://vexirahost.com
NEXT_PUBLIC_API_URL=https://api.vexirahost.com/api/v1

# Postgres (container-internal)
POSTGRES_USER=vexira
POSTGRES_PASSWORD=CHANGE-ME-strong-db-password
POSTGRES_DB=vexira_host

# ─── Backend app ───────────────────────────────────────────────
APP_NAME=Vexira Host
APP_URL=https://vexirahost.com
API_URL=https://api.vexirahost.com
API_PUBLIC_URL=https://api.vexirahost.com/api/v1
API_PREFIX=api/v1
CORS_ORIGINS=https://vexirahost.com,https://www.vexirahost.com
LOG_LEVEL=info

# JWT (min 32 chars)
JWT_ACCESS_SECRET=CHANGE-ME-strong-access-secret-min-32-chars
JWT_REFRESH_SECRET=CHANGE-ME-strong-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Storage
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.vexirahost.com/api/v1/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://api.vexirahost.com/api/v1/auth/github/callback
FRONTEND_AUTH_CALLBACK_URL=https://vexirahost.com/auth/callback

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=admin@vexirahost.com

# Hosting / payments
HOSTING_CREDENTIALS_KEY=CHANGE-ME-hosting-encryption-key-min-32-chars
PAYMENT_PROVIDER=kapital
KAPITAL_USERNAME=
KAPITAL_PASSWORD=
KAPITAL_IS_DEV=false
KAPITAL_REDIRECT_URL=https://api.vexirahost.com/api/v1/payments/kapital/callback
KAPITAL_RETURN_URL=https://vexirahost.com/payment/result
KAPITAL_LANGUAGE=az

REGISTRAR_PROVIDER=mock
PROXMOX_PROVIDER=mock
