{
  "name": "@vexira/frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Vexira Host customer-facing web application",
  "scripts": {
    "dev": "next dev --turbo --port 3000",
    "build": "next build",
    "start": "next start --port 3000",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
