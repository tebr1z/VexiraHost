# Vexira Host — Backend Environment Template
# Copy to .env and fill in values. Never commit secrets.
# Canlı URL-lər: ../../deploy/URLS.env
# Production şablon: .env.production.example

# ─── Application ───────────────────────────────────────────────
NODE_ENV=development
APP_NAME=Vexira Host
# Local:
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
API_PUBLIC_URL=http://localhost:4000/api/v1
# Production:
# APP_URL=https://vexirahost.com
# API_URL=https://api.vexirahost.com
# API_PUBLIC_URL=https://api.vexirahost.com/api/v1
PORT=4000
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000
# CORS_ORIGINS=https://vexirahost.com,https://www.vexirahost.com
LOG_LEVEL=debug

# ─── Database (PostgreSQL) ─────────────────────────────────────
DATABASE_URL=postgresql://postgres:1234@localhost:5432/vexira_host?schema=public

# ─── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ─── JWT / Auth ────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Storage ───────────────────────────────────────────────────
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
STORAGE_R2_BUCKET=
STORAGE_R2_ACCOUNT_ID=
STORAGE_R2_ACCESS_KEY=
STORAGE_R2_SECRET_KEY=

# ─── OAuth ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback
# GOOGLE_CALLBACK_URL=https://api.vexirahost.com/api/v1/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/api/v1/auth/github/callback
# GITHUB_CALLBACK_URL=https://api.vexirahost.com/api/v1/auth/github/callback
FRONTEND_AUTH_CALLBACK_URL=http://localhost:3000/auth/callback
# FRONTEND_AUTH_CALLBACK_URL=https://vexirahost.com/auth/callback

# ─── SMTP / Email ───────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Domain Registrar ────────────────────────────────────────────
REGISTRAR_PROVIDER=mock

# ─── Proxmox / VPS ───────────────────────────────────────────────
PROXMOX_PROVIDER=mock
PROXMOX_API_URL=
PROXMOX_TOKEN_ID=
PROXMOX_TOKEN_SECRET=
PROXMOX_DEFAULT_NODE=pve-fra-01

# ─── Hosting credentials encryption ─────────────────────────────
HOSTING_CREDENTIALS_KEY=change-me-hosting-encryption-key-min-32-chars

# ─── Payments (Kapital Bank Ecommerce) ──────────────────────────
# mock = instant fake charge (no bank) | kapital = HPP redirect
PAYMENT_PROVIDER=kapital
KAPITAL_USERNAME=
KAPITAL_PASSWORD=
# true = txpgtst.kapitalbank.az | false = e-commerce.kapitalbank.az
# Admin panel (/t4abriz/panel/system) test/production seçimi DB-də saxlanır və .env-dən üstündür.
KAPITAL_IS_DEV=true
# URL admin panel ortamından avtomatik gəlir — KAPITAL_BASE_URL istifadə olunmur.
# Local: localhost callbacks OK for HPP return on same machine.
# Production: use public HTTPS API + frontend URLs (see deploy/URLS.env).
KAPITAL_REDIRECT_URL=http://localhost:4000/api/v1/payments/kapital/callback
KAPITAL_RETURN_URL=http://localhost:3000/payment/result
# KAPITAL_REDIRECT_URL=https://api.vexirahost.com/api/v1/payments/kapital/callback
# KAPITAL_RETURN_URL=https://vexirahost.com/payment/result
KAPITAL_LANGUAGE=az
